# =============================================================================
# FloodShield Environment Configuration
# =============================================================================
# Copy this file to .env and update values for your environment.
# Do NOT commit .env to version control.

# ─────────────────────────────────────────────
# Database Configuration
# ─────────────────────────────────────────────
# Connection string for asyncpg (used by SQLAlchemy)
DATABASE_URL=postgresql+asyncpg://floodshield:floodshield@localhost:5432/floodshield

# PostgreSQL credentials (also used by docker-compose)
POSTGRES_USER=floodshield
POSTGRES_PASSWORD=floodshield
POSTGRES_DB=floodshield

# ─────────────────────────────────────────────
# Application Settings
# ─────────────────────────────────────────────
# Secret key for JWT signing - MUST change in production
SECRET_KEY=change-me-in-production

# Enable mock mode for development (uses fake providers)
MOCK_MODE=true

# API route prefixes
API_PREFIX=/v1
INTERNAL_PREFIX=/internal

# ─────────────────────────────────────────────
# Provider Configuration
# ─────────────────────────────────────────────
# AI provider: noop | openai | anthropic
AI_PROVIDER=noop

# Map provider: mock | mapbox | google
MAP_PROVIDER=mock

# Weather provider: mock | openweathermap | weatherapi
WEATHER_PROVIDER=mock

# Notification provider: mock | wechat | sms
NOTIFICATION_PROVIDER=mock

# ─────────────────────────────────────────────
# Real Provider API Keys
# ─────────────────────────────────────────────
# Uncomment and fill these when MOCK_MODE=false

# Weather API
# WEATHER_API_KEY=

# Map API
# MAP_API_KEY=

# SMS (Twilio or similar)
# SMS_API_KEY=
# SMS_API_SECRET=

# WeChat Official Account
# WECHAT_APP_ID=
# WECHAT_APP_SECRET=

# ─────────────────────────────────────────────
# Deployment & Infrastructure
# ─────────────────────────────────────────────
# Redis URL (uncomment when redis service is enabled)
# REDIS_URL=redis://localhost:6379/0

# Logging level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
