# =============================================================================
# FloodShield Git Ignore
# =============================================================================

# ─────────────────────────────────────────────
# Python
# ─────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
.venv/
venv/
ENV/
env/

# Testing
.pytest_cache/
.coverage
coverage/
htmlcov/
.tox/
.nox/

# Type checking
.mypy_cache/
.pytype/

# ─────────────────────────────────────────────
# Node.js / Next.js / Taro
# ─────────────────────────────────────────────
node_modules/
.next/
out/
dist/
.taro/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─────────────────────────────────────────────
# Environment & Secrets
# ─────────────────────────────────────────────
.env
.env.local
.env.*.local
!.env.example

# ─────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────
*.db
*.sqlite3
*.sqlite

# ─────────────────────────────────────────────
# OS Files
# ─────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
*.swp
*.swo
*~

# ─────────────────────────────────────────────
# IDE
# ─────────────────────────────────────────────
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# ─────────────────────────────────────────────
# Docker
# ─────────────────────────────────────────────
docker-compose.override.yml
